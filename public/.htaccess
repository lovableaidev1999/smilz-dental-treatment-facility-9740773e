RewriteEngine On
RewriteBase /

# ── Disable directory indexes (prevents Hostinger placeholder from leaking) ──
Options -Indexes
DirectoryIndex index.html

# ── Correct MIME types ──
AddType text/css .css
AddType application/javascript .js .mjs
AddType image/svg+xml .svg
AddType image/webp .webp
AddType font/woff2 .woff2
AddType application/json .json

# ── WordPress date-based URL redirects → /blog/[slug] ──
RewriteRule ^(\d{4})/(\d{2})/([^/]+)/?$ /blog/$3 [R=301,L]
RewriteRule ^(\d{4})/(\d{2})/(\d{2})/([^/]+)/?$ /blog/$4 [R=301,L]

# ── Legacy WordPress page redirects → modern equivalents ──
RedirectMatch 301 ^/diestema/?$ /services/diastema-correction
RedirectMatch 301 ^/smile-designing/?$ /services/smile-designing
RedirectMatch 301 ^/referral-register/?$ /referral
RedirectMatch 301 ^/login-form/?$ /admin/login
RedirectMatch 301 ^/wp-admin/?.*$ /admin/login
RedirectMatch 301 ^/wp-login\.php.*$ /admin/login

# ── Skip static assets from SPA fallback ──
# NOTE: txt and xml are included so files like /deploy-marker.txt, /robots.txt,
# /sitemap.xml, and /llms.txt are served as real files (or return a clean 404)
# instead of falling through to the SPA index.html. The verify-deploy CI step
# depends on /deploy-marker.txt returning plain text.
RewriteCond %{REQUEST_URI} \.(css|js|mjs|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|json|map|txt|xml)$ [NC]
RewriteRule ^ - [L]

# ── SPA fallback ──
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# ── GZIP compression ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# ── Browser caching ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# ── Cache-Control headers ──
<IfModule mod_headers.c>
  # index.html — no cache so updates appear immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Versioned/hashed assets — immutable long cache
  <FilesMatch "\.(js|css|mjs|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — long cache
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|ico|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ── Security headers ──
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
